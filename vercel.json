{
    "name": "learn-ngrow",
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": "nextjs",
    "buildCommand": "npm run build --workspace @learn-ngrow/web",
    "outputDirectory": "apps/web/.next",
    "installCommand": "npm ci",
    "devCommand": "npm run dev --workspace @learn-ngrow/web",
    "ignoreCommand": "git diff --quiet HEAD^ HEAD -- . ':!.github' ':!README.md'"
}